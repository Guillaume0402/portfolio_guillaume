# Nom du projet Docker (sert aux noms de conteneurs/volumes)
COMPOSE_PROJECT_NAME=app

APP_ENV=dev
APP_TZ=Europe/Paris

# Ports publiés sur ta machine
WEB_PORT=8080
PMA_PORT=8081
DB_PUBLISHED_PORT=3307

# DB (dans le réseau docker)
DB_HOST=db
DB_PORT=3306
DB_NAME=app
DB_USER=app_user
DB_PASSWORD=app_password

MYSQL_ROOT_PASSWORD=root

# Mailpit
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

